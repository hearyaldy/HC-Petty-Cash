rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Helper function to check if user owns this staff record
    function isStaffOwner(staffId) {
      return request.auth != null &&
        firestore.get(/databases/(default)/documents/staff/$(staffId)).data.userId == request.auth.uid;
    }

    // Staff photos - admins can write, all authenticated users can read
    match /staff_photos/{fileName} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Staff documents - admins can write to any, staff can write to their own folder
    match /staff_documents/{staffId}/{fileName} {
      allow read: if request.auth != null;
      // Allow write if admin OR if user owns this staff record (staff.userId == auth.uid)
      allow write: if request.auth != null && (
        isAdmin() || 
        isStaffOwner(staffId)
      );
    }

    // General files - allow all authenticated users
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
