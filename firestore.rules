rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for authentication and authorization
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isManager() {
      return isAuthenticated() && getUserRole() == 'manager';
    }

    function isFinance() {
      return isAuthenticated() && getUserRole() == 'finance';
    }

    function canApprove() {
      return isManager() || isFinance() || isAdmin();
    }

    function canReadMedia() {
      return isAuthenticated();
    }

    function canWriteMediaProduction(production) {
      return isAuthenticated();
    }

    function canWriteMediaEngagement(engagement) {
      return isAuthenticated() && (
        isAdmin() ||
        engagement.enteredById == request.auth.uid
      );
    }

    function canWriteMediaForProductionId(productionId) {
      return isAuthenticated();
    }

    // Check if user owns a staff record (staff.userId == auth.uid)
    function isStaffOwner(staffId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/staff/$(staffId)).data.userId == request.auth.uid;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      // Anyone authenticated can read user profiles (for display names, etc.)
      allow read: if isAuthenticated();

      // Users can update their own profile (except role field)
      allow update: if isOwner(userId) &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));

      // Allow authenticated users to create their own user document
      // This is needed because when admin creates a user via Firebase Auth,
      // the new user is automatically signed in, so they need to create their own doc
      allow create: if isAuthenticated() && request.auth.uid == userId;

      // Only admins can delete users and update other users' profiles
      allow delete: if isAdmin();
      allow update: if isAdmin();
    }

    // Reports collection
    match /reports/{reportId} {
      // All authenticated users can read reports
      // (UI will filter based on role)
      allow read: if isAuthenticated();

      // Any authenticated user can create reports
      // Must set themselves as custodian
      allow create: if isAuthenticated() &&
        request.resource.data.custodianId == request.auth.uid;

      // Custodian can update their own draft reports
      // Approvers can update any report
      allow update: if isAuthenticated() && (
        (resource.data.custodianId == request.auth.uid && resource.data.status == 'draft') ||
        canApprove()
      );

      // Only admin can delete reports
      allow delete: if isAdmin();
    }

    // Cash Advances collection
    match /cash_advances/{advanceId} {
      // Owners and approvers can read
      allow read: if isAuthenticated() && (
        resource.data.requesterId == request.auth.uid || canApprove()
      );

      // Any authenticated user can create their own cash advance
      allow create: if isAuthenticated() &&
        request.resource.data.requesterId == request.auth.uid;

      // Owner can update draft advances; approvers can update any
      allow update: if isAuthenticated() && (
        (resource.data.requesterId == request.auth.uid && resource.data.status == 'draft') ||
        canApprove()
      );

      // Owner can delete draft advances; admin can delete any
      allow delete: if isAuthenticated() && (
        (resource.data.requesterId == request.auth.uid && resource.data.status == 'draft') ||
        isAdmin()
      );
    }

    // Project Reports collection
    match /project_reports/{projectId} {
      // All authenticated users can read project reports
      // (UI will filter based on role)
      allow read: if isAuthenticated();

      // Any authenticated user can create project reports
      // Must set themselves as custodian
      allow create: if isAuthenticated() &&
        request.resource.data.custodianId == request.auth.uid;

      // Custodian can update their own draft project reports
      // Approvers can update any project report
      allow update: if isAuthenticated() && (
        (resource.data.custodianId == request.auth.uid && resource.data.status == 'draft') ||
        canApprove()
      );

      // Only admin can delete project reports
      allow delete: if isAdmin();
    }

    // Transactions collection
    match /transactions/{transactionId} {
      // All authenticated users can read transactions
      allow read: if isAuthenticated();

      // Any authenticated user can create transactions
      // Must set themselves as requestor
      allow create: if isAuthenticated() &&
        request.resource.data.requestorId == request.auth.uid;

      // Requestor can update draft transactions
      // Approvers can update status and approval-related fields
      allow update: if isAuthenticated() && (
        (resource.data.requestorId == request.auth.uid && resource.data.status == 'draft') ||
        canApprove()
      );

      // Only admin can delete transactions
      allow delete: if isAdmin();
    }

    // Settings collection
    match /settings/{settingId} {
      // All authenticated users can read settings
      allow read: if isAuthenticated();

      // All authenticated users can create/update settings
      // (admin-only features like org settings are gated in the UI)
      allow create, update: if isAuthenticated();

      // Only admins can delete settings
      allow delete: if isAdmin();
    }

    // Student profiles collection
    match /student_profiles/{userId} {
      // Students can read their own profile, admins/managers/finance can read all
      allow read: if isAuthenticated() && (isOwner(userId) || canApprove());

      // Students can create their own profile during onboarding
      allow create: if isAuthenticated() && request.auth.uid == userId;

      // Students can update their own profile, admins/managers can update any
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin() || isManager());

      // Only admins can delete profiles
      allow delete: if isAdmin();
    }

    // Student timesheets collection
    match /student_timesheets/{timesheetId} {
      // Students can read their own timesheets, admins can read all
      allow read: if isAuthenticated();

      // Students can create their own timesheets
      allow create: if isAuthenticated();

      // Students can update their own timesheets (draft status), admins can update any
      allow update: if isAuthenticated();

      // Students can delete their own timesheets, admins can delete any
      allow delete: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid || isAdmin()
      );
    }

    // Student monthly reports collection
    match /student_monthly_reports/{reportId} {
      // Students can read their own reports, admins can read all
      allow read: if isAuthenticated();

      // Students can create their own monthly reports
      allow create: if isAuthenticated();

      // Students can update their own draft reports, admins can update any
      allow update: if isAuthenticated();

      // Students can delete their own reports, admins can delete any
      allow delete: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid || isAdmin()
      );
    }

    // Media Productions collection
    match /media_productions/{productionId} {
      allow read: if canReadMedia();
      allow create: if canWriteMediaProduction(request.resource.data);
      allow update: if canWriteMediaProduction(resource.data);
      allow delete: if isAdmin();
    }

    // Media Seasons collection
    match /media_seasons/{seasonId} {
      allow read: if canReadMedia();
      allow create: if canWriteMediaForProductionId(request.resource.data.productionId);
      allow update: if canWriteMediaForProductionId(resource.data.productionId);
      allow delete: if isAdmin();
    }

    // Media Episodes collection
    match /media_episodes/{episodeId} {
      allow read: if canReadMedia();
      allow create: if canWriteMediaForProductionId(request.resource.data.productionId);
      allow update: if canWriteMediaForProductionId(resource.data.productionId);
      allow delete: if isAdmin();
    }

    // Media Engagements collection
    match /media_engagements/{engagementId} {
      allow read: if canReadMedia();
      allow create: if canWriteMediaEngagement(request.resource.data);
      allow update: if canWriteMediaEngagement(resource.data);
      allow delete: if canWriteMediaEngagement(resource.data);
    }

    match /media_yearly_stats/{statsId} {
      allow read: if canReadMedia();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /media_period_reports/{reportId} {
      allow read: if canReadMedia();
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Traveling Reports Collection
    match /traveling_reports/{reportId} {
      // Anyone authenticated can read
      allow read: if isAuthenticated();

      // Users can create their own reports
      allow create: if isAuthenticated()
        && request.resource.data.reporterId == request.auth.uid;

      // Users can update their own draft reports
      // Owner can submit their own report
      // Admin can approve/reject/revert submitted reports
      allow update: if isAuthenticated() && (
        // Owner can update draft reports
        (resource.data.reporterId == request.auth.uid
         && resource.data.status == 'draft')
        // Or owner can submit their own report
        || (resource.data.reporterId == request.auth.uid
            && resource.data.status == 'draft'
            && request.resource.data.status == 'submitted')
        // Or admin can approve/reject/revert reports
        || (isAdmin()
            && resource.data.status in ['submitted', 'approved', 'rejected']
            && request.resource.data.status in ['approved', 'rejected', 'draft'])
      );

      // Users can delete their own draft reports, admin can delete any
      allow delete: if isAuthenticated() && (
        (resource.data.reporterId == request.auth.uid
          && resource.data.status == 'draft')
        || isAdmin()
      );
    }

    // Traveling Per Diem Entries Collection
    match /traveling_per_diem_entries/{entryId} {
      // Anyone authenticated can read
      allow read: if isAuthenticated();

      // Users can create entries for their own draft reports
      allow create: if isAuthenticated()
        && exists(/databases/$(database)/documents/traveling_reports/$(request.resource.data.reportId))
        && get(/databases/$(database)/documents/traveling_reports/$(request.resource.data.reportId)).data.reporterId == request.auth.uid
        && get(/databases/$(database)/documents/traveling_reports/$(request.resource.data.reportId)).data.status == 'draft';

      // Users can update entries for their own draft reports
      allow update: if isAuthenticated()
        && exists(/databases/$(database)/documents/traveling_reports/$(resource.data.reportId))
        && get(/databases/$(database)/documents/traveling_reports/$(resource.data.reportId)).data.reporterId == request.auth.uid
        && get(/databases/$(database)/documents/traveling_reports/$(resource.data.reportId)).data.status == 'draft';

      // Users can delete entries from their own draft reports
      allow delete: if isAuthenticated()
        && exists(/databases/$(database)/documents/traveling_reports/$(resource.data.reportId))
        && get(/databases/$(database)/documents/traveling_reports/$(resource.data.reportId)).data.reporterId == request.auth.uid
        && get(/databases/$(database)/documents/traveling_reports/$(resource.data.reportId)).data.status == 'draft';
    }

    // Income Reports collection
    match /income_reports/{reportId} {
      // Report owners and approvers can read; admins/managers/finance need list access
      allow read: if isAuthenticated() && (
        isOwner(resource.data.createdById) || canApprove()
      );

      // Authenticated user creates their own report
      allow create: if isAuthenticated()
        && request.resource.data.createdById == request.auth.uid;

      // Owner can edit while draft or submit; approvers can transition submitted reports
      allow update: if isAuthenticated() && (
        (
          resource.data.createdById == request.auth.uid
          && resource.data.status == 'draft'
        ) || (
          canApprove()
          && resource.data.status in ['submitted', 'underReview']
        )
      );

      // Owner can delete draft; admins can delete any
      allow delete: if isAuthenticated() && (
        (resource.data.createdById == request.auth.uid
          && resource.data.status == 'draft') || isAdmin()
      );
    }

    // Income Entries collection
    match /income_entries/{entryId} {
      // All authenticated users can read entries
      // (filtering is done at the application level based on report access)
      allow read: if isAuthenticated();

      // Create only if user owns the parent report and it is draft
      allow create: if isAuthenticated()
        && exists(/databases/$(database)/documents/income_reports/$(request.resource.data.reportId))
        && get(/databases/$(database)/documents/income_reports/$(request.resource.data.reportId)).data.createdById == request.auth.uid
        && get(/databases/$(database)/documents/income_reports/$(request.resource.data.reportId)).data.status == 'draft';

      // Update only if user owns the parent report and it is draft
      allow update: if isAuthenticated()
        && exists(/databases/$(database)/documents/income_reports/$(resource.data.reportId))
        && get(/databases/$(database)/documents/income_reports/$(resource.data.reportId)).data.createdById == request.auth.uid
        && get(/databases/$(database)/documents/income_reports/$(resource.data.reportId)).data.status == 'draft';

      // Delete only if user owns the parent report and it is draft
      allow delete: if isAuthenticated()
        && exists(/databases/$(database)/documents/income_reports/$(resource.data.reportId))
        && get(/databases/$(database)/documents/income_reports/$(resource.data.reportId)).data.createdById == request.auth.uid
        && get(/databases/$(database)/documents/income_reports/$(resource.data.reportId)).data.status == 'draft';
    }

    // Purchase Requisitions collection
    match /purchase_requisitions/{requisitionId} {
      // Owners can read their own requisitions, HR/Admin can read all
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.requesterId ||
        isAdmin() ||
        isManager() ||
        isFinance()
      );

      // Any authenticated user can create requisitions
      allow create: if isAuthenticated();

      // Users can update draft requisitions, approvers can update submitted requisitions
      allow update: if isAuthenticated() && (
        resource.data.status == 'draft' ||
        canApprove()
      );

      // Users can delete draft requisitions, admin can delete any
      allow delete: if isAuthenticated() && (
        resource.data.status == 'draft' || isAdmin()
      );
    }

    // Purchase Requisition Items collection
    match /purchase_requisition_items/{itemId} {
      // Owners can read their own requisition items, HR/Admin can read all
      allow read: if isAuthenticated() &&
        exists(/databases/$(database)/documents/purchase_requisitions/$(resource.data.requisitionId)) &&
        (
          get(/databases/$(database)/documents/purchase_requisitions/$(resource.data.requisitionId)).data.requesterId == request.auth.uid ||
          isAdmin() ||
          isManager() ||
          isFinance()
        );

      // Create only if the parent requisition is draft
      allow create: if isAuthenticated()
        && exists(/databases/$(database)/documents/purchase_requisitions/$(request.resource.data.requisitionId))
        && get(/databases/$(database)/documents/purchase_requisitions/$(request.resource.data.requisitionId)).data.status == 'draft';

      // Update only if the parent requisition is draft
      allow update: if isAuthenticated()
        && exists(/databases/$(database)/documents/purchase_requisitions/$(resource.data.requisitionId))
        && get(/databases/$(database)/documents/purchase_requisitions/$(resource.data.requisitionId)).data.status == 'draft';

      // Delete only if the parent requisition is draft
      allow delete: if isAuthenticated()
        && exists(/databases/$(database)/documents/purchase_requisitions/$(resource.data.requisitionId))
        && get(/databases/$(database)/documents/purchase_requisitions/$(resource.data.requisitionId)).data.status == 'draft';
    }

    // Staff collection - HR records
    match /staff/{staffId} {
      // All authenticated users can read staff records (for salary/benefits management, directory, etc.)
      allow read: if isAuthenticated();

      // Users can create their own staff record (when submitting HR data)
      // userId must match their auth UID
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      // Users can update their own staff record, admins can update any
      allow update: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());

      // Users can delete their own staff record, admins can delete any
      allow delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Staff Documents collection
    match /staff_documents/{documentId} {
      // All authenticated users can read staff documents
      allow read: if isAuthenticated();

      // Admins can create/delete any, staff can create/delete their own documents
      allow create: if isAuthenticated() && (
        isAdmin() || 
        isStaffOwner(request.resource.data.staffId)
      );
      
      allow delete: if isAuthenticated() && (
        isAdmin() || 
        isStaffOwner(resource.data.staffId)
      );

      // Admins can update document descriptions
      allow update: if isAdmin() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['description']);
    }

    // Salary Benefits collection
    match /salary_benefits/{salaryBenefitsId} {
      // All authenticated users can read salary benefits records
      allow read: if isAuthenticated();

      // Only admins can create, update, or delete salary benefits records
      allow create, update, delete: if isAdmin();
    }

    // Employment Letter Templates collection
    match /employment_letter_templates/{templateId} {
      // All authenticated users can read templates
      allow read: if isAuthenticated();

      // Only admins can create, update, or delete templates
      allow create, update, delete: if isAdmin();
    }

    // Employment Letters collection
    match /employment_letters/{letterId} {
      // All authenticated users can read employment letters
      allow read: if isAuthenticated();

      // Only admins can create, update, or delete employment letters
      allow create, update, delete: if isAdmin();
    }

    // HR Data Submissions collection
    match /hr_data_submissions/{submissionId} {
      // Authenticated users can create their own submissions
      allow create: if isAuthenticated();

      // Users can read their own submissions, HR personnel and admins can read all
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.submittedBy ||
         isAdmin() ||
         isManager() ||
         isFinance());

      // Users can update their own submissions (for auto-sync status updates)
      // Admins can update any submission
      allow update: if isAuthenticated() &&
        (request.auth.uid == resource.data.submittedBy || isAdmin());

      // Users can delete their own submissions, admins can delete any
      allow delete: if isAuthenticated() &&
        (request.auth.uid == resource.data.submittedBy || isAdmin());
    }

    // Annual Leave Requests collection
    match /annual_leave_requests/{requestId} {
      // Staff can create their own requests
      allow create: if isAuthenticated() &&
        request.resource.data.requesterId == request.auth.uid &&
        request.resource.data.status == 'submitted' &&
        request.resource.data.approvedBy == null &&
        request.resource.data.approvedAt == null &&
        request.resource.data.actionNumber == null;

      // Owner can read their own, HR/Admin can read all
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.requesterId ||
        isAdmin() ||
        isManager() ||
        isFinance()
      );

      // Only HR/Admin can approve/reject/update
      allow update: if isAuthenticated() && (
        isAdmin() || isManager() || isFinance()
      ) && (
        // Prevent changing requester ownership
        request.resource.data.requesterId == resource.data.requesterId
      );

      // Only admin can delete
      allow delete: if isAdmin();
    }

    // Equipment Inventory collection
    match /equipment/{equipmentId} {
      // All authenticated users can read equipment
      allow read: if isAuthenticated();

      // All authenticated users can create equipment
      allow create: if isAuthenticated();

      // All authenticated users can update equipment (for check-in/out)
      allow update: if isAuthenticated();

      // Only admins can delete equipment
      allow delete: if isAdmin();
    }

    // Equipment Checkouts collection
    match /equipment_checkouts/{checkoutId} {
      // All authenticated users can read checkouts
      allow read: if isAuthenticated();

      // All authenticated users can create checkouts (when checking out)
      allow create: if isAuthenticated();

      // All authenticated users can update checkouts (when returning)
      allow update: if isAuthenticated();

      // Only admins can delete checkout records
      allow delete: if isAdmin();
    }

    // Equipment History collection (for tracking checkout/return history)
    match /equipment_history/{historyId} {
      // All authenticated users can read equipment history
      allow read: if isAuthenticated();

      // All authenticated users can create history entries
      allow create: if isAuthenticated();

      // Only admins can update or delete history records
      allow update, delete: if isAdmin();
    }

    // Payment Rates collection (for student labor hourly rates)
    match /payment_rates/{rateId} {
      // All authenticated users can read payment rates
      allow read: if isAuthenticated();

      // Only admins can create, update, or delete payment rates
      allow create, update, delete: if isAdmin();
    }

    // Meetings collection (ADCOM & Board meetings)
    match /meetings/{meetingId} {
      // All authenticated users can read meetings
      allow read: if isAuthenticated();

      // Only admins can create meetings
      allow create: if isAdmin();

      // Only admins can update meetings
      allow update: if isAdmin();

      // Only admins can delete meetings
      allow delete: if isAdmin();
    }

    // Meeting Agendas collection
    match /meeting_agendas/{agendaId} {
      // All authenticated users can read agendas
      allow read: if isAuthenticated();

      // Only admins can create agendas
      allow create: if isAdmin();

      // Only admins can update agendas
      allow update: if isAdmin();

      // Only admins can delete agendas
      allow delete: if isAdmin();
    }

    // Meeting Minutes collection
    match /meeting_minutes/{minutesId} {
      // All authenticated users can read minutes
      allow read: if isAuthenticated();

      // Only admins can create minutes
      allow create: if isAdmin();

      // Only admins can update minutes
      allow update: if isAdmin();

      // Only admins can delete minutes
      allow delete: if isAdmin();
    }

    // Meeting Action Items collection
    match /meeting_action_items/{actionItemId} {
      // All authenticated users can read action items
      allow read: if isAuthenticated();

      // Only admins can create action items
      allow create: if isAdmin();

      // Admins can update any action item
      // Assignees can update their own action items (status, completedNotes, completedAt)
      allow update: if isAuthenticated() && (
        isAdmin() ||
        resource.data.assigneeId == request.auth.uid
      );

      // Only admins can delete action items
      allow delete: if isAdmin();
    }

    // ADCOM Agendas collection
    match /adcom_agendas/{agendaId} {
      // All authenticated users can read ADCOM agendas
      allow read: if isAuthenticated();

      // Only admins can create ADCOM agendas
      allow create: if isAdmin();

      // Only admins can update ADCOM agendas
      allow update: if isAdmin();

      // Only admins can delete ADCOM agendas
      allow delete: if isAdmin();
    }

    // ADCOM Minutes collection
    match /adcom_minutes/{minutesId} {
      // All authenticated users can read ADCOM minutes
      allow read: if isAuthenticated();

      // Only admins can create ADCOM minutes
      allow create: if isAdmin();

      // Only admins can update ADCOM minutes
      allow update: if isAdmin();

      // Only admins can delete ADCOM minutes
      allow delete: if isAdmin();
    }

    // Meeting Templates collection
    match /meetingTemplates/{templateId} {
      // All authenticated users can read meeting templates
      allow read: if isAuthenticated();

      // Only admins can create meeting templates
      allow create: if isAdmin();

      // Only admins can update meeting templates
      allow update: if isAdmin();

      // Only admins can delete meeting templates
      allow delete: if isAdmin();
    }

    // Organizations collection (for inventory separation)
    match /organizations/{organizationId} {
      // All authenticated users can read organizations
      allow read: if isAuthenticated();

      // Only admins can create organizations
      allow create: if isAdmin();

      // Only admins can update organizations
      allow update: if isAdmin();

      // Only admins can delete organizations
      allow delete: if isAdmin();
    }
  }
}
